# Vera 3.0 — пример .env. Скопируй в .env и заполни.

# ─── Postgres ─────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-postgres

# ─── Secrets ──────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
TOKEN_SECRET=<32-byte-hex-from-openssl>
INTERNAL_SECRET=<32-byte-hex-from-openssl>

# ─── Langfuse ─────────────────────────────────────────────────────────
LANGFUSE_SECRET=<32-byte-hex>
LANGFUSE_SALT=<16-byte-hex>

# ─── Telegram ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<bot-token-from-BotFather>
TELEGRAM_API_ID=<api-id-from-my.telegram.org>
TELEGRAM_API_HASH=<api-hash-from-my.telegram.org>
TELEGRAM_PHONE=+<international-format>
OWNER_TELEGRAM_ID=<your-telegram-user-id>

# ─── Gmail OAuth ──────────────────────────────────────────────────────
GMAIL_CLIENT_ID=<from-google-cloud-console>
GMAIL_CLIENT_SECRET=<from-google-cloud-console>

# ─── Neo4j Aura (опционально для graph) ───────────────────────────────
NEO4J_URI=neo4j+s://<your-instance>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<from-aura>
NEO4J_DATABASE=<your-db-name>

# ─── Cost caps ────────────────────────────────────────────────────────
VERA_DAILY_GLOBAL_CAP_USD=2.0
