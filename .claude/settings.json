{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(ssh hetzner-root *)",
      "Bash(python *)",
      "Bash(uvicorn *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/guard_bash.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/guard_file.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/check_js_refs.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/session_note.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
